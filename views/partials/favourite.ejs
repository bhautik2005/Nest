<div class="absolute top-4 right-4 z-10">
  <% 
    let isFav = false;
    // Check if the home._id is in the user's favourite array
    if (typeof user !== 'undefined' && user && user.favourite) {
      isFav = user.favourite.some(favId => favId.toString() === home._id.toString());
    } else if (typeof isFavourite !== 'undefined' && isFavourite) {
      // Fallback if passed explicitly (e.g. from favourite-list where all are true)
      isFav = true;
    }
  %>
  <form method="POST" action="<%= isFav ? '/favourite/delete/' + home._id : '/favourite' %>">
    <% if (!isFav) { %>
      <input type="hidden" name="homeId" value="<%= home._id %>">
    <% } %>
    <button type="submit" class="heart-animation bg-white p-2 rounded-full shadow-lg hover:shadow-xl transition-all hover:scale-110">
      <% if (isFav) { %>
        <!-- Filled Red Heart -->
        <svg class="w-5 h-5 text-red-500 fill-current" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
          </path>
        </svg>
      <% } else { %>
        <!-- Empty Gray Heart -->
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
          </path>
        </svg>
      <% } %>
    </button>
  </form>
</div>